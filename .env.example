# Optional — required for the Media Kit contact form to send email.
# Create a free API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=

# Defaults to joachim@noobwork.no when unset.
CONTACT_TO_EMAIL=

# Defaults to Resend onboarding sender until a verified domain is configured.
CONTACT_FROM_EMAIL=

# Optional — for scripts/generate-atmosphere.mjs (local dev only; never deploy to Vercel).
# Create at https://cloud.higgsfield.ai → API keys.
# Format: KEY_ID:KEY_SECRET (or use HF_API_KEY + HF_API_SECRET instead).
HF_CREDENTIALS=
